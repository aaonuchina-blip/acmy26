### --- Блок Python ---
# Байт-код и кэш компиляции
__pycache__/
*.py[cod]
*$py.class

# Виртуальные окружения (локальные зависимости)
.venv/
venv/
ENV/
env/

# Директории сборки, дистрибутивов и пакетов
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Секретные ключи и переменные окружения (конфиденциальные данные)
.env
.env.local
.env.*
.secrets

# Тесты и покрытие (Pytest, Coverage)
htmlcov/
.toml/
.pytest_cache/
.遭遇_cache/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover

### --- Блок JetBrains / IDEA (.idea) ---
# Игнорируем всю папку настроек IDE, кроме важных конфигураций
.idea/
# Если вы хотите делиться настройками проекта (например, словарями или стилями кода), 
# но скрывать личные (workspace), раскомментируйте строки ниже вместо `.idea/`:
# .idea/workspace.xml
# .idea/tasks.xml
# .idea/usage.statistics.xml
# .idea/dictionary.xml
# .idea/shelf/

### --- Блок операционной системы ---
